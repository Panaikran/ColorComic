SECRET_KEY=change-this-to-a-random-string
COLORCOMIC_DEVICE=auto
COLOR_TRANSFER_STRENGTH=0.5

# OpenRouter key — used by BOTH the LLM image mode and the text-only
# color director (guided coloring). Leave empty to run fully offline.
OPENROUTER_API_KEY=

# Vision image mode (mode = "llm"): the model that PAINTS pages
OPENROUTER_MODEL=google/gemini-2.5-flash-image
OPENROUTER_MODALITIES=image,text
OPENROUTER_MAX_INPUT_EDGE=1600

# Guided coloring (auto mode): local CLIP labels regions, mc-v2 paints;
# a TEXT-ONLY model just picks the palette (it never sees images).
# Set the exact model id from openrouter.ai/models (e.g. DeepSeek v4 flash).
GUIDED_HINTS=1
# LLM color director default: 0 = off (no API spend) — users can still
# enable it per job from the upload page. Set 1 to default it on.
LLM_DIRECTOR=0
OPENROUTER_DIRECTOR_MODEL=deepseek/deepseek-chat
DIRECTOR_TIMEOUT=60

# Post-processing color realism
SKIN_TONE_CORRECTION=1
